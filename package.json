{
  "name": "specmaster",
  "private": true,
  "version": "0.2.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "dev:api": "node server/index.mjs",
    "build": "vue-tsc -b && vite build",
    "preview": "vite preview",
    "start": "node server/index.mjs",
    "test": "node --test",
    "test:unit": "node --test test/unit/*.test.mjs",
    "test:integration": "node --test test/integration/*.test.mjs",
    "test:e2e": "node --test test/e2e/*.test.mjs",
    "e2e": "playwright test",
    "e2e:human": "node e2e/run-humanized.mjs",
    "e2e:report": "allure generate ./allure-results -o ./allure-report --clean",
    "test:ui": "vitest run",
    "test:ui:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.909.0",
    "@aws-sdk/s3-request-presigner": "^3.909.0",
    "@element-plus/icons-vue": "^2.1.0",
    "@opentelemetry/auto-instrumentations-node": "^0.67.0",
    "@opentelemetry/exporter-trace-otlp-http": "^0.203.0",
    "@opentelemetry/sdk-node": "^0.203.0",
    "axios": "^1.13.5",
    "better-sqlite3": "^12.2.0",
    "busboy": "^1.6.0",
    "d3": "^7.9.0",
    "element-plus": "^2.13.2",
    "ioredis": "^5.7.0",
    "jose": "^6.1.0",
    "kysely": "^0.28.7",
    "mysql2": "^3.15.0",
    "pdfjs-dist": "^5.4.624",
    "pg": "^8.16.3",
    "pinia": "^3.0.4",
    "prom-client": "^15.1.3",
    "redlock": "^5.0.0-beta.2",
    "vue": "^3.5.25",
    "vue-router": "^5.0.3"
  },
  "devDependencies": {
    "@playwright/test": "^1.55.0",
    "@types/node": "^24.10.1",
    "@vitejs/plugin-vue": "^6.0.2",
    "@vitest/coverage-v8": "^3.2.4",
    "@vue/test-utils": "^2.4.6",
    "@vue/tsconfig": "^0.8.1",
    "allure-commandline": "^2.35.1",
    "allure-playwright": "^3.4.0",
    "jsdom": "^27.0.0",
    "sass": "^1.97.3",
    "testcontainers": "^11.6.0",
    "typescript": "~5.9.3",
    "vite": "^7.3.1",
    "vitest": "^3.2.4",
    "vue-tsc": "^3.1.5"
  }
}
